{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Build Graph Project",
            "command": "cl.exe",
            "args": [
                "/Zi",
                "/EHsc",
                "/nologo",

                "main.cpp",
                "dfs.cpp",
                "bfs.cpp",

                "/Fe:main.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ],
    "version": "2.0.0"
}